generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// BondhuOS AI Command Center - Database Schema
// ------------------------------------------------------

// 1. Customer / Lead Data
model Customer {
  id             String    @id @default(cuid())
  bondhumartId   String?   @unique // ID from the Laravel system
  name           String
  phone          String    @unique
  email          String?
  district       String?
  thana          String?   // Automatically parsed from address
  city           String?
  address        String?
  
  // Dynamic columns
  customData     Json?     // Stores dynamically created columns like Email, specific custom text, etc.
  
  // AI Generated labels & Stats
  label          String?   // e.g., "High Value", "Risky"
  totalOrders    Int       @default(0)
  totalSpent     Float     @default(0.0)
  lastOrderAt    DateTime?
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  orders         Order[]
  chatLogs       ChatLog[]
}

// 2. Product Data
model Product {
  id             String    @id @default(cuid())
  bondhumartId   String?   @unique // ID from the Laravel system
  name           String
  price          Float
  imageUrl       String?
  categoryName   String?   // Old category field
  stock          Int       @default(0)
  description    String?   @db.Text
  isAdActive     Boolean   @default(false) // Ad tracking
  
  // New Product Management fields
  categoryId     String?
  category       Category? @relation(fields: [categoryId], references: [id])
  bundleOffers   Json?
  media          Json?
  aiSalesman     Json?
  pageContent    Json?
  extraSettings  Json?
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  orders         Order[]
  reviews        Review[]
  coupons        Coupon[]  @relation("CouponToProduct")
}

// 12. Category
model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  
  products    Product[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// 13. Review
model Review {
  id             String    @id @default(cuid())
  productId      String
  product        Product   @relation(fields: [productId], references: [id])
  
  customerName   String
  customerImage  String?
  rating         Int       @default(5)
  comment        String    @db.Text
  images         Json?     // Array of image URLs
  
  status         String    @default("Pending") // Pending, Approved, Rejected
  adminCreated   Boolean   @default(false)
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// 14. Coupon
model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  discountType   String    @default("Fixed") // Fixed, Percentage
  discountValue  Float
  minOrderAmount Float?
  
  isActive       Boolean   @default(true)
  showOnLanding  Boolean   @default(false)
  
  products       Product[] @relation("CouponToProduct")
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// 15. Page Design & Builder (Main Site)
model PageDesign {
  id             String    @id @default(cuid())
  type           String    @unique // Header, Footer, FrontPage, Checkout, ThankYou, AboutUs, ReturnPolicy, Terms, Privacy
  content        Json?     // Grid builder blocks config
  
  isActive       Boolean   @default(true)
  updatedAt      DateTime  @updatedAt
}

// 16. Landing Page Builder
model LandingPage {
  id             String    @id @default(cuid())
  slug           String    @unique
  title          String
  
  // Basic settings
  productId      String?   // Product attached to this landing page
  themeColor     String    @default("#319b03")
  bgColor        String    @default("#F5F3FF")
  deliveryInside Float     @default(60)
  deliveryOutside Float    @default(120)
  freeDelivery   Boolean   @default(false)
  requirePhone   Boolean   @default(true)
  isPublished    Boolean   @default(false)
  
  // Builder content
  blocks         Json?     // Array of dragged-and-dropped section blocks
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// 3. Order Data
model Order {
  id               String    @id @default(cuid())
  bondhumartId     String?   @unique // ID from the Laravel system
  customerId       String
  customer         Customer  @relation(fields: [customerId], references: [id])
  productId        String
  product          Product   @relation(fields: [productId], references: [id])
  
  quantity         Int       @default(1)
  amount           Float
  deliveryCharge   Float     @default(0.0)
  
  // Dynamic columns for specific orders
  customData       Json?
  status           String    @default("Pending") // Pending, Confirmed, On Hold, Shipped, Delivered, Cancelled, Returning, Return Received
  cancelledReason  String?
  
  // Courier details
  courierName      String?
  courierTracking  String?
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deliveredAt      DateTime?

  courierBookings  CourierBooking[]
}

// 4. Broadcast History
model Broadcast {
  id             String    @id @default(cuid())
  targetSegment  String    // e.g., "Cancelled last month"
  message        String    @db.Text
  imageUrl       String?
  sentCount      Int       @default(0)
  channel        String    // WhatsApp, Email
  
  createdAt      DateTime  @default(now())
}

// 5. AI Chat Log
model ChatLog {
  id             String    @id @default(cuid())
  customerPhone  String
  customer       Customer? @relation(fields: [customerPhone], references: [phone])
  
  message        String    @db.Text // User message (text/audio converted to text)
  aiResponse     String    @db.Text // AI's reply
  
  createdAt      DateTime  @default(now())
}

// 6. Courier Booking
model CourierBooking {
  id             String    @id @default(cuid())
  orderId        String
  order          Order     @relation(fields: [orderId], references: [id])
  
  courierName    String    // Steadfast, Pathao, RedX
  trackingNo     String?
  status         String    @default("Booked")
  
  bookedAt       DateTime  @default(now())
}

// 7. Knowledge Base
model KnowledgeBase {
  id             String    @id @default(cuid())
  topic          String
  content        String    @db.Text
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// 8. Store Settings
model StoreSettings {
  id               String    @id @default(cuid())
  pixelId          String?
  deliveryInside   Float     @default(80)
  deliveryOutside  Float     @default(150)
  bannerText       String?
  contactPhone     String?
  
  updatedAt        DateTime  @updatedAt
}

// 9. Blocked Customers (Fraud Prevention)
model BlockedCustomer {
  id             String    @id @default(cuid())
  name           String?
  phone          String    @unique
  reason         String?   @db.Text
  createdAt      DateTime  @default(now())
}

// 10. Notification Templates
model NotificationTemplate {
  id             String    @id @default(cuid())
  type           String    @unique // e.g., 'Order Received', 'Order Confirmed', 'Order Cancelled'
  isActive       Boolean   @default(true)
  message        String    @db.Text
  channel        String    @default("WhatsApp") // WhatsApp, SMS, Email
  updatedAt      DateTime  @updatedAt
}

// 11. Message Logs (System outbound logs)
model MessageLog {
  id             String    @id @default(cuid())
  phone          String
  type           String    // WhatsApp, SMS, Email
  status         String    // success, failed
  content        String    @db.Text
  error          String?   @db.Text
  createdAt      DateTime  @default(now())
}
